{
  "version": 1,
  "require_product_steps": true,
  "require_frontend_if_applicable": true,
  "require_playwright_for_frontend": false,
  "min_jtbd_scenarios": 6,
  "profiles": {
    "native-macos": {
      "description": "Native macOS SwiftPM MenuBarExtra app changes.",
      "patterns": [
        "Package.swift",
        "Resources/**",
        "Sources/**",
        "Tests/**",
        "script/**",
        ".codex/**",
        ".jtbd-done-gate.json"
      ],
      "steps": [
        "Swift build",
        "Swift tests",
        "Helper script syntax",
        "Helper plist syntax",
        "App bundle launch",
        "Live menu bar power smoke"
      ],
      "require_product_steps": true,
      "require_frontend_if_applicable": false
    },
    "public-launch": {
      "description": "Static landing page, Vercel config, docs, packaging, and public repo launch changes.",
      "patterns": [
        "README.md",
        "LICENSE",
        "docs/**",
        "site/**",
        "scripts/**",
        "site-tests/**",
        "package.json",
        "package-lock.json",
        "playwright.config.mjs",
        "vercel.json",
        ".vercelignore",
        ".github/workflows/**",
        ".jtbd-done-gate.json"
      ],
      "steps": [
        "Site static claim check",
        "Site Playwright UI",
        "DMG packaging dry run",
        "Open-source secret scan"
      ],
      "require_product_steps": true,
      "require_frontend_if_applicable": true
    },
    "full-release": {
      "description": "All native macOS and public-launch validation steps."
    }
  },
  "steps": [
    {
      "name": "Swift build",
      "kind": "quality",
      "run": "/usr/bin/arch -arm64 swift build",
      "profiles": ["native-macos", "full-release"],
      "affects": ["Package.swift", "Sources/**"]
    },
    {
      "name": "Swift tests",
      "kind": "test",
      "run": "/usr/bin/arch -arm64 swift test",
      "profiles": ["native-macos", "full-release"],
      "affects": ["Package.swift", "Sources/**", "Tests/**"]
    },
    {
      "name": "Helper script syntax",
      "kind": "quality",
      "run": ".build/debug/LidSwitch --print-helper | zsh -n /dev/stdin && .build/debug/LidSwitch --print-install-script | zsh -n /dev/stdin && .build/debug/LidSwitch --print-uninstall-script | zsh -n /dev/stdin",
      "profiles": ["native-macos", "full-release"],
      "affects": ["Sources/LidSwitch/Services/PrivilegedHelperManager.swift"]
    },
    {
      "name": "Helper plist syntax",
      "kind": "quality",
      "run": ".build/debug/LidSwitch --print-plist | plutil -lint -",
      "profiles": ["native-macos", "full-release"],
      "affects": ["Sources/LidSwitch/Services/PrivilegedHelperManager.swift"]
    },
    {
      "name": "App bundle launch",
      "kind": "product",
      "run": "./script/build_and_run.sh --verify",
      "profiles": ["native-macos", "full-release"],
      "affects": ["Package.swift", "Resources/**", "Sources/**", "script/build_and_run.sh"]
    },
    {
      "name": "Live menu bar power smoke",
      "kind": "ui",
      "run": "./script/validate_live_state.sh",
      "profiles": ["native-macos", "full-release"],
      "affects": ["Package.swift", "Sources/**", "script/**"]
    },
    {
      "name": "Site static claim check",
      "kind": "quality",
      "run": "npm run site:check",
      "profiles": ["public-launch", "full-release"],
      "affects": ["site/**", "scripts/check-site.mjs", "scripts/check-icons.mjs", "scripts/check-public-links.mjs", "package.json", "package-lock.json", "vercel.json", "README.md", "docs/**", "screenshots/**"]
    },
    {
      "name": "Site Playwright UI",
      "kind": "ui",
      "run": "PLAYWRIGHT_JSON_OUTPUT_FILE=\"$JTBD_DONE_GATE_REPORT_DIR/playwright-results.json\" npm run site:test",
      "profiles": ["public-launch", "full-release"],
      "affects": ["site/**", "site-tests/**", "playwright.config.mjs", "package.json", "package-lock.json"],
      "expects": {
        "format": "playwright-json",
        "path": "{REPORT_DIR}/playwright-results.json",
        "min_tests": 6
      }
    },
    {
      "name": "DMG packaging dry run",
      "kind": "quality",
      "run": "./script/build_dmg.sh --dry-run",
      "profiles": ["public-launch", "full-release"],
      "affects": ["script/build_dmg.sh", "docs/INSTALL.md", "docs/DISTRIBUTION.md", "README.md"]
    },
    {
      "name": "Open-source secret scan",
      "kind": "quality",
      "run": "node scripts/scan-public-secrets.mjs",
      "profiles": ["public-launch", "full-release"],
      "affects": ["**/*"]
    }
  ],
  "report": {
    "dir": ".jtbd-done-gate/reports",
    "cleanup_success_paths": ["{REPORT_DIR}/tmp"],
    "retention": {
      "keep_latest": 5,
      "max_age_days": 14,
      "max_total_mb": 512,
      "prune_after_run": false
    }
  }
}

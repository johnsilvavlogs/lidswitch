{
  "name": "lidswitch-public-launch",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "site:serve": "python3 -m http.server 4173 --bind 127.0.0.1 --directory site",
    "site:check": "node scripts/check-site.mjs && node scripts/check-contrast.mjs && node scripts/check-icons.mjs && node scripts/check-public-links.mjs",
    "links:check": "node scripts/check-public-links.mjs",
    "icons:check": "node scripts/check-icons.mjs",
    "public:hygiene": "node scripts/check-public-hygiene.mjs && node scripts/test-public-hygiene.mjs",
    "public:hygiene:check": "node scripts/check-public-hygiene.mjs",
    "public:hygiene:test": "node scripts/test-public-hygiene.mjs",
    "site:test": "playwright test",
    "site:test:ci": "playwright test --reporter=list,json",
    "package:dmg": "./script/build_dmg.sh",
    "package:verify": "./script/validate_dmg.sh",
    "scan:secrets": "node scripts/scan-public-secrets.mjs",
    "scan:secrets:test": "node scripts/test-public-secrets.mjs",
    "scan:secrets:release": "node scripts/scan-public-secrets.mjs --release-artifacts --path dist",
    "launch:check-public": "node scripts/check-public-github.mjs",
    "analytics:downloads": "node scripts/report-downloads.mjs",
    "validate:site": "npm run site:check && npm run site:test"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0"
  }
}

; Revision 7: deny by default.  The compiler sees a host-created, immutable
; source snapshot, never the checkout.  Add a literal toolchain path only when
; a qualified-Mac probe proves it is required.
(version 1)
(deny default)
(allow file-read-data (literal "/"))
(allow file-read-metadata (literal "/"))
(allow file-read-metadata (literal "/usr"))
(allow file-read-metadata (literal "/private"))
(allow file-read-metadata (literal "/private/tmp"))
(allow file-read-metadata (literal "/Library"))
(allow file-read-metadata (literal "/Library/Developer"))
(allow file-read-metadata (literal "@CLT_ROOT@"))
(allow file-read-metadata (literal "/Applications"))
(allow file-read-metadata (literal "/Applications/Xcode.app"))
(allow file-read-metadata (literal "/Applications/Xcode.app/Contents"))
(allow file-read-metadata (literal "@XCODE_DEVELOPER@"))
(allow file-read-metadata (subpath "@XCODE_DEVELOPER@"))
(allow file-read* (literal "@XCODE_TOOLCHAIN@"))
(allow file-read-metadata (literal "@XCODE_SHARED_FRAMEWORKS@"))
(allow file-read* (subpath "@XCODE_SHARED_FRAMEWORKS@"))
(allow file-read-metadata (literal "@XCODE_PLATFORM_FRAMEWORKS@"))
(allow file-read* (subpath "@XCODE_PLATFORM_FRAMEWORKS@"))
(allow file-read-metadata (literal "@XCODE_PLATFORM_PRIVATE_FRAMEWORKS@"))
(allow file-read* (subpath "@XCODE_PLATFORM_PRIVATE_FRAMEWORKS@"))
(allow file-read-metadata (literal "@XCODE_PLATFORM_USR_LIB@"))
(allow file-read* (subpath "@XCODE_PLATFORM_USR_LIB@"))
(allow file-read* (literal "@XCODE_LIBXCRUN@"))
(allow file-read* (literal "@XCODE_SWIFT_PLUGIN_SERVER@"))
(allow file-read* (literal "/dev/null"))
(allow file-read* (literal "@EXEC_ROOT@"))
(allow file-read* (subpath "@EXEC_ROOT@"))
(allow file-read* (subpath "@SOURCE_ROOT@"))
(allow file-read* (subpath "@HELPER_SOURCE_ROOT@"))
(allow file-read* (subpath "@APP_SOURCE_ROOT@"))
(allow file-read* (subpath "/usr/bin"))
(allow file-read* (subpath "/bin"))
(allow file-read* (subpath "/usr/lib"))
(allow file-read* (subpath "/System/Library"))
; Darwin resolves some system-private framework firmlinks through this immutable
; system mirror before sandbox matching (for example MobileDevice.framework).
(allow file-read* (subpath "/Library/Apple/System/Library"))
(allow file-read* (subpath "/Library/Developer"))
(allow file-read* (subpath "@CLT_ROOT@"))
(allow file-read* (subpath "@SDKROOT@"))
(allow file-read* (subpath "@XCODE_TOOLCHAIN@"))
(allow file-read* (subpath "@XCODE_SDKROOT@"))
(allow file-read* (subpath "@XCODE_XCTEST_FRAMEWORK@"))
(allow file-read* (subpath "@XCODE_XCTEST_MODULE@"))
(allow file-read* (literal "@XCODE_XCTEST_SUPPORT@"))
(allow file-read* (literal "@XCODE_XCTEST_TOOL@"))
(allow file-read* (subpath "/private/var/db/dyld"))
(allow file-read* (literal "/etc/localtime"))
(allow process-exec (literal "/usr/bin/arch"))
(allow process-exec (literal "/usr/bin/swift"))
(allow process-exec (literal "/usr/bin/swiftc"))
(allow process-exec (literal "/usr/bin/xcrun"))
(allow process-exec (literal "/usr/bin/clang"))
(allow process-exec (literal "/usr/bin/clang++"))
(allow process-exec (literal "/usr/bin/ld"))
(allow process-exec (literal "/usr/bin/codesign"))
; Exact inert fixture children used by process-containment and script-parser
; tests. They inherit this deny-default profile and cannot reach power,
; launchd, network, persistence, or the checkout.
(allow process-exec (literal "/bin/bash"))
(allow process-exec (literal "/bin/sh"))
(allow process-exec (literal "/bin/sleep"))
(allow process-exec (literal "/usr/bin/yes"))
(allow process-exec (literal "@SWIFT_TOOL@"))
(allow process-exec (literal "@SWIFTC_TOOL@"))
(allow process-exec (literal "@SWIFT_FRONTEND_TOOL@"))
(allow process-exec (literal "@CLT_ROOT@/usr/bin/swift-test"))
(allow process-exec (literal "@CLT_ROOT@/usr/bin/swift-build"))
(allow process-exec (literal "@CLT_ROOT@/usr/bin/swift-package"))
(allow process-exec (literal "@CLT_ROOT@/usr/bin/swift-driver"))
(allow process-exec (literal "@CLT_ROOT@/usr/bin/swiftc"))
(allow process-exec (literal "@CLT_ROOT@/usr/bin/clang++"))
(allow process-exec (literal "@CLANG_TOOL@"))
(allow process-exec (literal "@CLANGXX_TOOL@"))
(allow process-exec (literal "@LD_TOOL@"))
(allow process-exec (literal "@DSYMUTIL_TOOL@"))
(allow process-exec (literal "@XCODE_SWIFT_TOOL@"))
(allow process-exec (literal "@XCODE_SWIFTC_TOOL@"))
(allow process-exec (literal "@XCODE_SWIFT_FRONTEND_TOOL@"))
(allow process-exec (literal "@XCODE_CLANG_TOOL@"))
(allow process-exec (literal "@XCODE_CLANGXX_TOOL@"))
(allow process-exec (literal "@XCODE_LD_TOOL@"))
(allow process-exec (literal "@XCODE_DSYMUTIL_TOOL@"))
(allow process-exec (literal "@XCODE_LIBTOOL_TOOL@"))
(allow process-exec (literal "@XCODE_SWIFT_PLUGIN_SERVER@"))
(allow process-exec (literal "@XCODE_XCTEST_TOOL@"))
(allow process-exec (literal "@XCODE_TOOLCHAIN@/usr/bin/swift-test"))
(allow process-exec (literal "@XCODE_TOOLCHAIN@/usr/bin/swift-build"))
(allow process-exec (literal "@XCODE_TOOLCHAIN@/usr/bin/swift-package"))
(allow process-exec (literal "@XCODE_TOOLCHAIN@/usr/bin/swift-driver"))
(allow process-exec (subpath "@EXEC_ROOT@"))
(allow process-fork)
(allow sysctl-read)
(allow signal (target self))
(allow signal (target children))
(allow mach-lookup (global-name "com.apple.diagnosticd"))
(deny file-link)
(deny file-clone)
(deny process-info-setcontrol)
(deny process-info-setcontrol (target self))
(deny mach-lookup)
(deny mach-register)
(deny mach-bootstrap)
(deny network*)
(deny appleevent-send)
(deny distributed-notification-post)
(deny darwin-notification-post)
(deny authorization-right-obtain)
(deny job-creation)
(deny iokit-open)
(deny sysctl-write)
(allow file-write* (literal "@EXEC_ROOT@"))
(allow file-write* (subpath "@EXEC_ROOT@"))
(deny file-write* (literal "@SOURCE_ROOT@"))
(deny file-write* (subpath "@SOURCE_ROOT@"))
(deny file-write* (literal "@HELPER_SOURCE_ROOT@"))
(deny file-write* (subpath "@HELPER_SOURCE_ROOT@"))
(deny file-write* (literal "@APP_SOURCE_ROOT@"))
(deny file-write* (subpath "@APP_SOURCE_ROOT@"))
(allow file-write-data (literal "/dev/null"))

(deny file-read* (literal "@CONTROL_ROOT@"))
(deny file-read* (subpath "@CONTROL_ROOT@"))
(deny file-write* (literal "@CONTROL_ROOT@"))
(deny file-write* (subpath "@CONTROL_ROOT@"))

; Production truth remains unreadable and unwritable inside XCTest. A benchmark
; may read only its explicit uninstalled candidate and the installed helper
; bytes needed for bounded comparison. Publication happens outside this profile.
(deny file-read* (subpath "@REAL_HOME@/Library/Application Support/LidSwitch"))
(deny file-read* (subpath "/Library/Application Support/LidSwitch"))
(deny file-read* (literal "/Library/LaunchDaemons/com.johnsilva.lidswitch.helper.plist"))
(deny file-read* (subpath "/Applications/LidSwitch.app"))
(deny file-read* (prefix "/Library/Preferences/SystemConfiguration/com.apple.PowerManagement."))
(deny file-read* (prefix "/Library/Preferences/com.apple.PowerManagement."))
(allow file-read-metadata (literal "@BENCHMARK_PARENT@"))
(allow file-read* (subpath "@BENCHMARK_APP@"))
(allow file-read* (literal "@BENCHMARK_HELPER@"))
(deny file-read* (literal "@REPO_ROOT@"))
(deny file-read* (subpath "@REPO_ROOT@"))
(deny file-write* (literal "@REPO_ROOT@"))
(deny file-write* (subpath "@REPO_ROOT@"))
(deny file-write* (subpath "@REAL_HOME@/Library/Application Support/LidSwitch"))
(deny file-write* (subpath "/Library/Application Support/LidSwitch"))
(deny file-write* (literal "/Library/LaunchDaemons/com.johnsilva.lidswitch.helper.plist"))
(deny file-write* (subpath "/Applications/LidSwitch.app"))

; Close authority, LaunchServices, ServiceManagement, background-task,
; authorization, launchd-job, and bootstrap confused-deputy routes. Tests may
; spawn supervised children but cannot create a new session or persistent job.
(deny mach-lookup (global-name "com.johnsilva.lidswitch.helper.control"))
(deny mach-lookup (global-name "com.apple.authd"))
(deny mach-lookup (global-name "com.apple.PowerManagement.control"))
(deny mach-lookup (global-name "com.apple.iokit.powerdxpc"))
(deny mach-lookup (global-name "com.apple.coreservices.launchservicesd"))
(deny mach-lookup (global-name "com.apple.LaunchServices"))
(deny mach-lookup (global-name "com.apple.lsd.open"))
(deny mach-lookup (global-name "com.apple.lsd.openurl"))
(deny mach-lookup (global-name "com.apple.lsd.xpc"))
(deny mach-lookup (global-name "com.apple.lsd.modifydb"))
(deny mach-lookup (global-name "com.apple.lsd.mapdb"))
(deny mach-lookup (global-name "com.apple.lsd.extensions"))
(deny mach-lookup (global-name "com.apple.lsd.icons"))
(deny mach-lookup (global-name "com.apple.lsd.advertisingidentifiers"))
(deny mach-lookup (global-name "com.apple.coreservices.appleevents"))
(deny mach-lookup (global-name "com.apple.coreservices.lsuseractivitymanager.xpc"))
(deny mach-lookup (global-name "com.apple.coreservices.sharedfilelistd.xpc"))
(deny mach-lookup (global-name "com.apple.ak.authorizationservices.xpc"))
(deny mach-lookup (global-name "com.apple.xpc.smd"))
(deny mach-lookup (global-name "com.apple.xpc.loginitemregisterd"))
(deny mach-lookup (global-name "com.apple.backgroundtaskmanagement"))
(deny mach-lookup (global-name "com.apple.backgroundtaskmanagement.notifications"))
(deny mach-lookup (global-name "com.apple.backgroundtaskmanagement.sfl"))
(deny mach-lookup (global-name "com.apple.backgroundtaskmanagementagent"))
(deny mach-lookup (global-name "com.apple.WorkflowServiceRunner"))
(deny mach-lookup (global-name "com.apple.systemevents"))
(deny mach-lookup (global-name "com.apple.loginwindow.LWWeeklyMessageTracer"))

; Direct executable and copied-alias routes to host mutation tools are both
; closed. Denied read-data prevents exec-through-a-copy for these exact files.
(deny process-exec (literal "/bin/launchctl"))
(deny process-exec (literal "/usr/bin/pmset"))
(deny process-exec (literal "/usr/bin/osascript"))
(deny process-exec (literal "/usr/bin/sudo"))
(deny process-exec (literal "/usr/bin/open"))
(deny process-exec (literal "/usr/bin/caffeinate"))
(deny process-exec (literal "/usr/sbin/systemsetup"))
(deny process-exec (literal "/Applications/LidSwitch.app/Contents/MacOS/LidSwitch"))
(deny process-exec (literal "/Library/Application Support/LidSwitch/Current/LidSwitchHelper"))
(deny process-exec (literal "/Library/Application Support/LidSwitch/LidSwitchHelper"))
(deny process-exec (literal "/Library/Application Support/LidSwitch/lidswitch-helper"))
(deny file-read-data (literal "/bin/launchctl"))
(deny file-read-data (literal "/usr/bin/pmset"))
(deny file-read-data (literal "/usr/bin/osascript"))
(deny file-read-data (literal "/usr/bin/sudo"))
(deny file-read-data (literal "/usr/bin/open"))
(deny file-read-data (literal "/usr/bin/caffeinate"))
(deny file-read-data (literal "/usr/sbin/systemsetup"))
